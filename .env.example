# Copy to .env and fill in. For Expo, use EXPO_PUBLIC_ prefix so vars are available in the app.
# Optional: install dotenv and it will be loaded from app.config.js when you run expo start.
#   npm install dotenv

# Gateway base URL
EXPO_PUBLIC_GATEWAY_URL=http://localhost:3000

# Certification body client DID (must match the DID document and VC)
EXPO_PUBLIC_CLIENT_DID=did:web:truganic.github.io:did-documents:clients:certification-body-client

# Private key for request signing (hex, no 0x prefix). VC for this DID must include scope write:agent-server
EXPO_PUBLIC_CLIENT_PRIVATE_KEY=
